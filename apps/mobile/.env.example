# Supabase project the mobile client talks to. When these are set (and not the
# placeholder), online multiplayer is enabled. In a PRODUCTION build these are
# required — a missing value throws at startup (F-07) instead of silently
# running offline. Use VITE_OFFLINE_MODE=true to run offline on purpose.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=replace-with-local-or-project-publishable-key

# Set to "true" to force single-device offline mode (skips Supabase entirely).
# VITE_OFFLINE_MODE=false
